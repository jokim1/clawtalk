# --- ClawRocket web server defaults ---
# Local-only installs can keep these defaults.
WEB_ENABLED=true
WEB_HOST=127.0.0.1
WEB_PORT=3210
WEB_SECURE_COOKIES=false
AUTH_DEV_MODE=true

# --- Public access (optional) ---
# Public mode is off by default. When you enable it, also set:
# - AUTH_DEV_MODE=false
# - WEB_SECURE_COOKIES=true
# - TRUSTED_PROXY_MODE=cloudflare or caddy
# - GOOGLE_OAUTH_* values
# - CLAWROCKET_PROVIDER_SECRET_KEY
# - INITIAL_OWNER_EMAIL (unless an owner already exists in the DB)
PUBLIC_MODE=false
INITIAL_OWNER_EMAIL=
TRUSTED_PROXY_MODE=none
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI=http://127.0.0.1:8788/api/v1/auth/slack/callback
CLAWROCKET_PROVIDER_SECRET_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_POOL=

# --- ClawRocket web talks real executor ---
# Enable real executor auto-selection by providing both:
# 1) provider auth (either ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN)
# 2) a valid alias-map JSON object below
TALK_EXECUTOR_DEFAULT_ALIAS=Mock
TALK_EXECUTOR_ALIAS_MODEL_MAP_JSON={"Gemini":"default","Opus4.6":"default","Haiku":"default","GPT-4o":"default","Opus":"default"}
TALK_EXECUTOR_WEB_GROUP_FOLDER=web-talks

{
  "name": "clawtalk",
  "version": "1.2.7",
  "description": "ClawTalk — multi-agent LLM Talks, a web product.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "wrangler dev",
    "check:webapp": "node scripts/ensure-webapp-installed.mjs",
    "install:webapp": "node scripts/install-webapp.mjs",
    "install:all": "npm install && npm run install:webapp",
    "dev:web": "npm run check:webapp && npm --prefix webapp run dev",
    "build:web": "npm run check:webapp && npm --prefix webapp run build",
    "test:web": "npm run check:webapp && npm --prefix webapp run test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "test": "node scripts/run-vitest.mjs run",
    "test:watch": "node scripts/run-vitest.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "exceljs": "^4.4.0",
    "hono": "^4.12.7",
    "jose": "^5.10.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.9",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.90.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
